<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog
    xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
    xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
    xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
        http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-4.27.xsd">

    <changeSet id="01-schema-and-extensions" author="nrf">
        <sql>CREATE EXTENSION IF NOT EXISTS postgis</sql>
    </changeSet>

    <changeSet id="01-coefficient-layer" author="nrf">
        <createTable tableName="coefficient_layer" schemaName="public">
            <column name="id" type="uuid">
                <constraints primaryKey="true" nullable="false"/>
            </column>
            <column name="version" type="integer">
                <constraints nullable="false"/>
            </column>
            <column name="geometry" type="geometry(MULTIPOLYGON,27700)">
                <constraints nullable="false"/>
            </column>
            <column name="crome_id" type="varchar"/>
            <column name="land_use_cat" type="varchar"/>
            <column name="nn_catchment" type="varchar"/>
            <column name="subcatchment" type="varchar"/>
            <column name="lu_curr_n_coeff" type="float8"/>
            <column name="lu_curr_p_coeff" type="float8"/>
            <column name="n_resi_coeff" type="float8"/>
            <column name="p_resi_coeff" type="float8"/>
            <column name="created_at" type="timestamptz" defaultValueComputed="now()">
                <constraints nullable="false"/>
            </column>
        </createTable>
        <createIndex indexName="ix_public_coefficient_layer_crome_id"
                     tableName="coefficient_layer" schemaName="public">
            <column name="crome_id"/>
        </createIndex>
        <createIndex indexName="ix_public_coefficient_layer_nn_catchment"
                     tableName="coefficient_layer" schemaName="public">
            <column name="nn_catchment"/>
        </createIndex>
        <createIndex indexName="ix_public_coefficient_layer_subcatchment"
                     tableName="coefficient_layer" schemaName="public">
            <column name="subcatchment"/>
        </createIndex>
        <createIndex indexName="ix_public_coefficient_layer_version"
                     tableName="coefficient_layer" schemaName="public">
            <column name="version"/>
        </createIndex>
        <sql>
            CREATE INDEX idx_coefficient_layer_geometry
            ON public.coefficient_layer USING GIST (geometry)
        </sql>
        <rollback>
            <dropTable tableName="coefficient_layer" schemaName="public"/>
        </rollback>
    </changeSet>

    <changeSet id="01-lookup-table" author="nrf">
        <createTable tableName="lookup_table" schemaName="public">
            <column name="id" type="uuid">
                <constraints primaryKey="true" nullable="false"/>
            </column>
            <column name="name" type="varchar">
                <constraints nullable="false"/>
            </column>
            <column name="version" type="integer">
                <constraints nullable="false"/>
            </column>
            <column name="data" type="jsonb">
                <constraints nullable="false"/>
            </column>
            <column name="schema" type="jsonb"/>
            <column name="description" type="varchar"/>
            <column name="source" type="varchar"/>
            <column name="license" type="varchar"/>
            <column name="created_at" type="timestamptz" defaultValueComputed="now()">
                <constraints nullable="false"/>
            </column>
        </createTable>
        <addUniqueConstraint tableName="lookup_table" schemaName="public"
                             columnNames="name, version"
                             constraintName="uq_lookup_name_version"/>
        <createIndex indexName="ix_public_lookup_table_name"
                     tableName="lookup_table" schemaName="public">
            <column name="name"/>
        </createIndex>
        <createIndex indexName="ix_public_lookup_table_version"
                     tableName="lookup_table" schemaName="public">
            <column name="version"/>
        </createIndex>
        <rollback>
            <dropTable tableName="lookup_table" schemaName="public"/>
        </rollback>
    </changeSet>

