    <!-- Nutrient mitigation layers -->

    <changeSet id="01-wwtw-catchments" author="nrf">
        <createTable tableName="wwtw_catchments" schemaName="public">
            <column name="id" type="uuid">
                <constraints primaryKey="true" nullable="false"/>
            </column>
            <column name="version" type="integer">
                <constraints nullable="false"/>
            </column>
            <column name="geometry" type="geometry(GEOMETRY,27700)">
                <constraints nullable="false"/>
            </column>
            <column name="name" type="varchar"/>
            <column name="attributes" type="jsonb"/>
            <column name="created_at" type="timestamptz" defaultValueComputed="now()">
                <constraints nullable="false"/>
            </column>
        </createTable>
        <createIndex indexName="ix_public_wwtw_catchments_version"
                     tableName="wwtw_catchments" schemaName="public">
            <column name="version"/>
        </createIndex>
        <createIndex indexName="ix_public_wwtw_catchments_name"
                     tableName="wwtw_catchments" schemaName="public">
            <column name="name"/>
        </createIndex>
        <sql>
            CREATE INDEX ix_public_wwtw_catchments_geometry
            ON public.wwtw_catchments USING GIST (geometry)
        </sql>
        <rollback>
            <dropTable tableName="wwtw_catchments" schemaName="public"/>
        </rollback>
    </changeSet>

